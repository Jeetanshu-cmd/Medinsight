{
  "version": 2,
  "routes": [
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/demo.html", "dest": "/demo.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}